{
  "claim": "Frozen activation probes can detect when a physiological law is incomplete and support selective abstention; this is an audit protocol, not intrinsic self-knowledge.",
  "equations": {
    "beer_lambert": "I_lambda(t) = I0 * exp(-(eps_HbO2 * c_HbO2 + eps_Hb * c_Hb) * L(t)); R = (AC_red/DC_red) / (AC_ir/DC_ir); SpO2 = f(R, calibration)",
    "moens_korteweg": "PWV = sqrt(E * h / (rho * D)); PTT = L / PWV; E(P) = E0 * exp(alpha * P); BP requires subject calibration"
  },
  "limitations": [
    "Simulators use simplified modified Beer-Lambert and Moens-Korteweg approximations.",
    "Not validated against clinical pulse oximetry or cuffless BP devices.",
    "Activation probes are external monitors, not intrinsic model uncertainty.",
    "Held-out corruptions test controlled law violations, not all real-world OOD.",
    "Do not use for clinical decision-making."
  ],
  "config": {
    "output_dir": "results/physics_credibility",
    "device": "cpu",
    "seeds": [
      0,
      1,
      2
    ],
    "epochs": 120,
    "experiment": "all",
    "quick": false
  },
